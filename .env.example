# Autobug Configuration

# Database (PostgreSQL for production)
DATABASE_URL="postgresql://user:password@localhost:5432/autobug?schema=public"

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379

# Server
PORT=3001
NODE_ENV=development

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Security
ENCRYPTION_KEY="your-32-character-encryption-key-here!!"
JWT_SECRET="your-jwt-secret-min-32-characters-long-here"

# SSH Configuration (key-based auth recommended)
SSH_HOST=your_server_ip
SSH_USER=autobug-deploy
SSH_KEY_PATH=/opt/autobug/.ssh/deploy_key
SSH_TIMEOUT_MS=30000

# Default Repository Path
DEFAULT_REPO_PATH=/var/www/html

# Safety Settings
DRY_RUN=false
REQUIRE_CONFIRMATION=false

# Groq AI Context Enhancement
GROQ_ENABLED=true
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_MS=30000
GROQ_MAX_TOKENS=4096
GROQ_TEMPERATURE=0.2
GROQ_FALLBACK_ON_ERROR=true

# File Upload (S3/R2 for production)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# S3_BUCKET=autobug-uploads
# S3_UPLOADS_PREFIX=uploads

# Stripe (for billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...
STRIPE_SUCCESS_URL=http://localhost:3000/admin.html?billing=success
STRIPE_CANCEL_URL=http://localhost:3000/admin.html?billing=cancel
